datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── 用户表 ────────────────────────────────────────
model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")

  sessions    Session[]
  evaluations Evaluation[]

  @@map("users")
}

// ─── 会话表 ────────────────────────────────────────
model Session {
  id        Int       @id @default(autoincrement())
  name      String
  status    String    @default("active") // active | archived
  sceneType String    @default("hybrid") @map("scene_type") // consult | promo | service | chat | hybrid
  userId    Int       @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id])
  messages    Message[]
  evaluations Evaluation[]

  @@map("sessions")
}

// ─── 消息表 ────────────────────────────────────────
model Message {
  id          Int      @id @default(autoincrement())
  sessionId   Int      @map("session_id")
  role        String   // user | assistant
  content     String
  messageType Int      @default(1) @map("message_type") // 1=text
  latencyMs   Int?     @map("latency_ms")   // AI 回复延迟
  ttftMs      Int?     @map("ttft_ms")      // 首 token 延迟
  rawResponse Json?    @map("raw_response") // SSE 原始响应
  createdAt   DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─── 评测表 ────────────────────────────────────────
model Evaluation {
  id           Int      @id @default(autoincrement())
  sessionId    Int      @map("session_id")
  userId       Int      @map("user_id")
  status       String   @default("pending") // pending | running | completed | failed
  sceneType    String?  @map("scene_type")  // consult | promo | service | chat | hybrid

  overallScore  Float?   @map("overall_score") // 0-100 scale

  // New: flexible dimension scores as JSON
  dimensionScores   Json?   @map("dimension_scores")   // DimensionScore[]
  checklistResults  Json?   @map("checklist_results")  // ChecklistItem[] (chat scene)
  ageStratification Json?   @map("age_stratification") // AgeStratification (chat scene)

  // Legacy 5-dimension columns (kept during migration)
  intentScore      Float?  @map("intent_score")
  intentReasoning  String? @map("intent_reasoning")
  intentDetails    Json?   @map("intent_details")

  contextScore     Float?  @map("context_score")
  contextReasoning String? @map("context_reasoning")
  contextDetails   Json?   @map("context_details")

  personaScore     Float?  @map("persona_score")
  personaReasoning String? @map("persona_reasoning")
  personaDetails   Json?   @map("persona_details")

  safetyScore      Float?  @map("safety_score")
  safetyReasoning  String? @map("safety_reasoning")
  safetyDetails    Json?   @map("safety_details")

  performanceScore     Float?  @map("performance_score")
  performanceReasoning String? @map("performance_reasoning")
  performanceDetails   Json?   @map("performance_details")

  suggestions     Json?    // 优化建议数组
  reportNarrative String?  @map("report_narrative") // 评测报告叙述

  llmModelUsed String?  @map("llm_model_used")
  createdAt    DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("evaluations")
}

// ─── 商品知识库文件表 (原 AI 模型数据库) ──────────────
model ModelFile {
  id         Int      @id @default(autoincrement())
  name       String
  format     String   // MD, PDF, Word, JPG, MP3, MP4
  quality    String   // 高, 中, 低
  validUntil String   @map("valid_until")
  source     String   // 小课堂, 双十一小课堂, etc.
  sizeBytes  Int?     @map("size_bytes")
  filePath   String?  @map("file_path")   // 存储路径
  mimeType   String?  @map("mime_type")
  content    String?  // 文件文本内容（MD/txt 等可读格式）
  sortOrder  Int      @default(0) @map("sort_order")
  replacedBy Int?     @map("replaced_by") // 软删除: 被哪个新文件替换
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  @@map("model_files")
}

// ─── QA 数据库 ──────────────────────────────────────
model QAFolder {
  id        Int      @id @default(autoincrement())
  name      String
  sceneType String   @default("consult") @map("scene_type") // consult | promo | service | chat
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  files QAFile[]

  @@map("qa_folders")
}

model QAFile {
  id         Int      @id @default(autoincrement())
  folderId   Int      @map("folder_id")
  name       String
  format     String   // txt, csv, json, md
  sizeBytes  Int      @default(0) @map("size_bytes")
  qaCount    Int      @default(0) @map("qa_count")
  filePath   String   @map("file_path")
  metadata   Json?    // { sourceDoc, category, userProfile, primaryNeed, rounds }
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  folder  QAFolder  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  entries QAEntry[]

  @@map("qa_files")
}

model QAEntry {
  id       Int     @id @default(autoincrement())
  fileId   Int     @map("file_id")
  round    Int     @default(1) // 对话轮次
  question String
  answer   String  @default("") // 可为空，模型生成
  category String?
  tags     Json?

  file QAFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("qa_entries")
}

// ─── 上传任务表 ──────────────────────────────────────
model UploadJob {
  id             String    @id @default(uuid())
  channel        String    // qa-database | knowledge-base
  status         String    @default("pending") // pending | processing | completed | failed
  totalFiles     Int       @default(0) @map("total_files")
  processedFiles Int       @default(0) @map("processed_files")
  failedFiles    Json?     @map("failed_files")
  userId         Int       @map("user_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  completedAt    DateTime? @map("completed_at")

  @@map("upload_jobs")
}

// ─── 系统配置表 ──────────────────────────────────────
model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}
